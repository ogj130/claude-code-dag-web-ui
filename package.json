{
  "name": "cc-web-ui",
  "version": "1.4.1",
  "description": "Claude Code DAG Web UI - Cross-platform Desktop Application",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "verify": "tsc --noEmit ; vitest run ; vite build"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.3.6",
    "crypto-js": "^4.2.0",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "flexsearch": "^0.8.212",
    "image-js": "^0.35.6",
    "loglevel": "^1.9.2",
    "lz-string": "^1.5.0",
    "mammoth": "^1.12.0",
    "openai": "^6.34.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "vectordb": "^0.21.2",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.5.14",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^3.2.4",
    "concurrently": "^9.1.2",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^27.0.1",
    "pino": "^9.6.0",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vitest": "^3.2.4"
  }
}
