{
  "name": "cc-web-ui-electron",
  "version": "1.4.0",
  "type": "module",
  "description": "Claude Code DAG Web UI - Electron Package for Windows, macOS, and Linux",
  "main": "dist/main.js",
  "author": {
    "name": "ogj130",
    "email": "ogj130@example.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ogj130/claude-code-dag-web-ui.git"
  },
  "scripts": {
    "build": "tsc && npm run build:server && npm run copy:frontend",
    "copy:frontend": "cp -R ../dist/. dist/",
    "build:main": "tsc",
    "build:server": "tsc -p tsconfig.server.json",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "express": "^4.21.2",
    "openai": "^6.34.0",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "vectordb": "^0.21.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/ws": "^8.5.14",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "com.ccwebui.app",
    "productName": "Claude Code Web UI",
    "copyright": "Copyright © 2026 ogj130",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Claude Code Web UI"
    },
    "asar": true,
    "asarUnpack": [
      "**/node_modules/vectordb/**/*.{node,dylib}",
      "**/node_modules/lancedb/**/*.{node,dylib}"
    ],
    "publish": {
      "provider": "github",
      "owner": "ogj130",
      "repo": "claude-code-dag-web-ui"
    }
  }
}
