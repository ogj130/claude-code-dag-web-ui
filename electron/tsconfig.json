{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "jsx": "react-jsx",
    "baseUrl": "..",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "../src/**/*"],
  "exclude": ["node_modules", "dist", "release", "../src/__tests__/**", "../src/**/*.test.ts", "../src/**/*.test.tsx"]
}
